local ElementsList = {
    pth_u_leaves = "Leaves",
    pth_u_fire = "Fire",
    pth_u_aqua = "Aqua",
    pth_u_ice = "Ice",
    pth_u_moon = "Moon",
    pth_u_sun = "Sun",
    pth_u_dark = "Dark",
    pth_u_lightning = "Lightning"
}

local ElementLabels = {}

for id, name in pairs(ElementsList) do
    local lbl = Instance.new("TextLabel")
    lbl.Parent = MainFrame
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, -20, 0, 20)
    lbl.Position = UDim2.new(0, 10, 0, 0)
