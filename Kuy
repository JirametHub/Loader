    lbl.TextSize = 13
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    ElementLabels[id] = lbl
end

-- ==========================================
-- [ LOGIC: เจาะหาข้อมูลเควสต์แบบเจาะลึก ]
-- ==========================================
task.spawn(function()
    while true do
        task.wait(1)
        pcall(function()
            local GetDataModule = require(ReplicatedStorage.Shared.GetData)
            local playerData = GetDataModule.GetData(player)
            if not playerData then return end

            local foundData = {}

            -- ใช้ GetDescendants() มุดหาโฟลเดอร์เควสต์ในทุกชั้นของ Data
            for _, item in ipairs(playerData:GetDescendants()) do
                if ElementsList[item.Name] then
                    local pVal = item:FindFirstChild("progress") and item.progress.Value or 0
                    local nVal = item:FindFirstChild("questneed") and item.questneed.Value or 500
                    
                    foundData[item.Name] = { progress = pVal, need = nVal }
                end
            end

            -- อัปเดต UI 
            for id, name in pairs(ElementsList) do
                local lbl = ElementLabels[id]
                if lbl then
                    if foundData[id] then
                        local current = foundData[id].progress
                        local max = foundData[id].need
                        lbl.Text = "  " .. name .. ": " .. current .. " / " .. max
                        
                        -- เปลี่ยนสีถ้าเต็ม
                        if current >= max then
                            lbl.TextColor3 = Color3.fromRGB(100, 255, 100) -- สีเขียว
                        else
                            lbl.TextColor3 = Color3.fromRGB(255, 255, 255) -- สีขาวปกติ
                        end
                    else
                        -- กรณีที่ยังไม่เคยเก็บธาตุนั้นได้เลย ข้อมูลยังไม่ถูกสร้างใน Data
                        lbl.Text = "  " .. name .. ": 0 / 500"
                        lbl.TextColor3 = Color3.fromRGB(150, 150, 150) -- สีเทา
                    end
                end
            end
        end)
    end
end)

