local function SmartAutoBuyMax(targetItemName)
    local GetDataModule = require(ReplicatedStorage.Shared.GetData)
    local playerData = GetDataModule.GetData(player)
    if not playerData then return 0, 0 end
    
    local merchantFolder = playerData:FindFirstChild("Merchant")
    local shopItem = merchantFolder and merchantFolder:FindFirstChild(targetItemName)
    if not shopItem then return 0, 0 end 
    
    local quantity = shopItem:FindFirstChild("Quantity"); local buyAmount = shopItem:FindFirstChild("BuyAmount")
    local totalStock = quantity and quantity.Value or 0; local alreadyBought = buyAmount and buyAmount.Value or 0
    local remainingStock = totalStock - alreadyBought
    if remainingStock <= 0 then return 0, 0 end 
    
    local itemStats = GetDataModule.GetItemStats(targetItemName)
    local maxLimit = itemStats and itemStats.Maximum or math.huge
    
    local currentAmount = 0
    if playerData:FindFirstChild("Items") and playerData.Items:FindFirstChild(targetItemName) then currentAmount = playerData.Items[targetItemName].Amount.Value
    elseif playerData:FindFirstChild("Data") and playerData.Data:FindFirstChild(targetItemName) then currentAmount = playerData.Data[targetItemName].Value end
    
    local spaceInInventory = maxLimit - currentAmount
    local finalBuyAmount = math.min(remainingStock, spaceInInventory)
    
    if finalBuyAmount > 0 then
        FireSafeRemote({"Remote", "Server", "Gameplay", "Merchant"}, targetItemName, finalBuyAmount)
        return finalBuyAmount, (currentAmount + finalBuyAmount)
    end
    return 0, 0
end

