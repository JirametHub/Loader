local function GetInventorySnapshot(playerData)
    local snap = { Currency = {}, Units = {}, Items = {} }
    if not playerData then return snap end
    
    local dataFolder = playerData:FindFirstChild("Data")
    if dataFolder then
        local gemObj = dataFolder:FindFirstChild("Gem") or dataFolder:FindFirstChild("Gems")
        local goldObj = dataFolder:FindFirstChild("Gold") or dataFolder:FindFirstChild("Coins")
        local solObj = dataFolder:FindFirstChild("Sol Token")
        
        snap.Currency.Gem = gemObj and SafeToNumber(gemObj.Value) or 0
        snap.Currency.Gold = goldObj and SafeToNumber(goldObj.Value) or 0
        snap.Currency.Sol = solObj and SafeToNumber(solObj.Value) or 0
    end
    
    local unitsFolder = playerData:FindFirstChild("Units") or playerData:FindFirstChild("Unit")
    if unitsFolder then
        for _, u in ipairs(unitsFolder:GetChildren()) do
            snap.Units[u.Name] = (snap.Units[u.Name] or 0) + 1
        end
    end
    
    local itemsFolder = playerData:FindFirstChild("Items")
    if itemsFolder then
        for _, i in ipairs(itemsFolder:GetChildren()) do
            local amtObj = i:FindFirstChild("Amount")
            if amtObj then
                snap.Items[i.Name] = (snap.Items[i.Name] or 0) + SafeToNumber(amtObj.Value)
            end
        end
    end
    
    return snap
end

local function CompareSnapshots(old, new, bannerName, amountStr, sellConfig, gachaUnits)
    bannerName = bannerName or "N/A"
    amountStr = amountStr or "0x"
    local currencyText = {}
    local unitsText = {}
    local itemsText = {}
    
    local goldDiff = (new.Currency.Gold or 0) - (old.Currency.Gold or 0)
    if goldDiff > 0 then table.insert(currencyText, "- Gold: +" .. FormatNumber(goldDiff) .. " (From Drops/Sell)") end
    
    local gemDiff = (new.Currency.Gem or 0) - (old.Currency.Gem or 0)
    if gemDiff > 0 then table.insert(currencyText, "- Gem: +" .. FormatNumber(gemDiff)) end
    
    local totalAmt = tonumber(amountStr:gsub("x", "")) or 0
    local keptUnits = {}
    local totalKept = 0
    for name, count in pairs(new.Units) do
        local oldC = old.Units[name] or 0
        if count > oldC then 
            local diff = count - oldC
            keptUnits[name] = diff
            totalKept = totalKept + diff
        end
    end

    if gachaUnits and #gachaUnits > 0 then
        local unitCounts = {}
        for _, name in ipairs(gachaUnits) do
            unitCounts[name] = (unitCounts[name] or 0) + 1
        end
        for name, count in pairs(unitCounts) do
            local status = " [SOLD]"
            if keptUnits[name] and keptUnits[name] > 0 then
                status = " [KEPT]"
                keptUnits[name] = keptUnits[name] - 1
            end
            table.insert(unitsText, "  👤 " .. name .. " (x" .. count .. ")" .. status)
        end
    else
        if totalKept > 0 then
            for name, count in pairs(keptUnits) do
                table.insert(unitsText, "  👤 " .. name .. " (x" .. FormatNumber(count) .. ") [KEPT]")
            end
        end
        if totalKept < totalAmt then
            local soldAmt = totalAmt - totalKept
            table.insert(unitsText, "  📦 Sold Units: " .. FormatNumber(soldAmt) .. " (Auto Sold)")
        end
    end
    
    for name, count in pairs(new.Items) do
        local oldC = old.Items[name] or 0
        if count > oldC then 
            table.insert(itemsText, "- " .. name .. " x" .. FormatNumber(count - oldC)) 
        end
    end
    
    local finalResult = {}
    if #currencyText > 0 then
        table.insert(finalResult, "[ Currency ]")
        for _, t in ipairs(currencyText) do table.insert(finalResult, t) end
    end
    if #unitsText > 0 then
        table.insert(finalResult, "\n[ Summon Results ]")
        for _, t in ipairs(unitsText) do table.insert(finalResult, t) end
    end
    if #itemsText > 0 then
        table.insert(finalResult, "\n[ Items ]")
        for _, t in ipairs(itemsText) do table.insert(finalResult, t) end
    end
    if #finalResult == 0 then finalResult = { "🧂 All Sold (เกลือจัดๆ) / No new Units." } end
    return finalResult
end

