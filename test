task.spawn(function()
    local GameEndedUI_Event = ReplicatedStorage:WaitForChild("Remote", 10)
    if GameEndedUI_Event then
        GameEndedUI_Event = GameEndedUI_Event:WaitForChild("Client", 10)
        if GameEndedUI_Event then
            GameEndedUI_Event = GameEndedUI_Event:WaitForChild("UI", 10)
            if GameEndedUI_Event then
                GameEndedUI_Event = GameEndedUI_Event:WaitForChild("GameEndedUI", 10)
            end
        end
    end

    if not GameEndedUI_Event then return end

    local currentRewards = {}

    GameEndedUI_Event.OnClientEvent:Connect(function(action, data)
        if not JHub.Flags.EnableWebhook then return end

        if action == "Rewards - Items" then
            -- เมื่อเกมส่งข้อมูลไอเทมดรอปมาให้ ให้เก็บไว้ในตัวแปรนี้ทันที
            currentRewards = data
            
        elseif action == "Update - EndedScreen" then
            -- เมื่อเกมแจ้งให้โชว์หน้าจอ End Screen ให้ดึงข้อมูลด่านพร้อมจัดส่ง Webhook
            pcall(function()
                local ValuesGame = ReplicatedStorage:FindFirstChild("Values") and ReplicatedStorage.Values:FindFirstChild("Game")
                if not ValuesGame then return end
                
                local gamemode = ValuesGame:FindFirstChild("Gamemode") and ValuesGame.Gamemode.Value or "N/A"
                local world = ValuesGame:FindFirstChild("World") and ValuesGame.World.Value or "N/A"
                local level = ValuesGame:FindFirstChild("Level") and ValuesGame.Level.Value or "N/A"
                local diff = ValuesGame:FindFirstChild("Difficulty") and ValuesGame.Difficulty.Value or "N/A"
                
                local rawTime = data.TotalTime or 0
                local formattedTime = tostring(rawTime)
                if type(rawTime) == "number" then
                    -- แปลงวินาทีเป็นฟอร์แมต 00:00:00
                    formattedTime = string.format("%02d:%02d:%02d", math.floor(rawTime/3600), math.floor(rawTime/60)%60, rawTime%60)
                end

                local GetDataModule = require(ReplicatedStorage.Shared.GetData)
                local PlayerData = GetDataModule.GetData(player)
                
                local playerLevel = "N/A"
                if PlayerData and PlayerData:FindFirstChild("Data") and PlayerData.Data:FindFirstChild("Level") then 
                    playerLevel = tostring(PlayerData.Data.Level.Value) 
                end

                local dropListText = ""
                
                -- ตรวจสอบของรางวัลพิเศษถ้ามีแนบมา
                if data.RewardsHead then
                    local cleanHeadInfo = tostring(data.RewardsHead):gsub("Rewards%s*|%s*", "")
                    dropListText = dropListText .. "🎯 [Special] : " .. cleanHeadInfo .. "\n"
                end

                -- แปลงข้อมูลของรางวัลที่ดักไว้มาเป็น Text
                if currentRewards and type(currentRewards) == "table" and #currentRewards > 0 then
                    for _, item in pairs(currentRewards) do
                        local itemName = "Unknown"
                        local itemAmount = "1"
                        
                        -- เช็คประเภทของข้อมูลเพราะเกมอาจจะส่งมาได้ทั้งแบบ Instance และ Table
                        if typeof(item) == "Instance" then
                            itemName = item.Name
                            if item:FindFirstChild("Amount") then
                                itemAmount = tostring(item.Amount.Value)
                            end
                        elseif type(item) == "table" then
                            itemName = item.Name or "Unknown"
                            if item.Amount then
                                itemAmount = tostring(item.Amount)
                            end
                        end
                        
                        local totalAmount = 0
                        if PlayerData then
                            if PlayerData:FindFirstChild("Items") and PlayerData.Items:FindFirstChild(itemName) then
                                totalAmount = PlayerData.Items[itemName].Amount.Value
                            elseif PlayerData:FindFirstChild("Data") and PlayerData.Data:FindFirstChild(itemName) then
                                totalAmount = PlayerData.Data[itemName].Value
                            end
                        end
                        
                        dropListText = dropListText .. "- " .. tostring(itemName) .. " (x" .. itemAmount .. ") [Total: " .. FormatNumber(totalAmount) .. "]\n"
                    end
                end

                if dropListText == "" then dropListText = "N/A" end
                
                local fullMapName = world .. " (" .. level .. ")"
                local gameStatus = gamemode .. " - " .. diff
                
                SendRewardsToDiscord(fullMapName, gameStatus, formattedTime, playerLevel, dropListText)
            end)
        end
    end)
end)

