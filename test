local FpsCapState = {
    CurrentMap = nil,
    Parts = {},
    Visuals = {},
    Effects = {},
    Meshes = {}
}

local function RestoreFpsCapMap()
    for inst, data in pairs(FpsCapState.Parts) do
        if inst and inst.Parent then
            pcall(function()
                inst.Material = data.Material
                inst.Reflectance = data.Reflectance
                inst.CastShadow = data.CastShadow
                inst.LocalTransparencyModifier = data.LocalTransparencyModifier
            end)
        end
    end

    for inst, data in pairs(FpsCapState.Visuals) do
        if inst and inst.Parent then
            pcall(function()
                inst.Transparency = data.Transparency
            end)
        end
    end

    for inst, data in pairs(FpsCapState.Effects) do
        if inst and inst.Parent then
            pcall(function()
                if data.Enabled ~= nil then
                    inst.Enabled = data.Enabled
                end
            end)
        end
    end

    for inst, data in pairs(FpsCapState.Meshes) do
        if inst and inst.Parent then
            pcall(function()
                if inst:IsA("MeshPart") then
                    inst.TextureID = data.TextureID
                elseif inst:IsA("SpecialMesh") then
                    inst.TextureId = data.TextureId
                end
            end)
        end
    end

    FpsCapState.CurrentMap = nil
    FpsCapState.Parts = {}
    FpsCapState.Visuals = {}
    FpsCapState.Effects = {}
    FpsCapState.Meshes = {}
end

local function ApplyFpsCapMap(targetMap)
    if not targetMap then return end
    RestoreFpsCapMap()
    FpsCapState.CurrentMap = targetMap

    for _, inst in ipairs(targetMap:GetDescendants()) do
        if inst:IsA("BasePart") then
            FpsCapState.Parts[inst] = {
                Material = inst.Material,
                Reflectance = inst.Reflectance,
                CastShadow = inst.CastShadow,
                LocalTransparencyModifier = inst.LocalTransparencyModifier
            }

            pcall(function()
                inst.Material = Enum.Material.SmoothPlastic
                inst.Reflectance = 0
                inst.CastShadow = false
                if not inst.CanCollide then
                    inst.LocalTransparencyModifier = 1
                else
                    inst.LocalTransparencyModifier = 0
                end
            end)

            if inst:IsA("MeshPart") then
                FpsCapState.Meshes[inst] = { TextureID = inst.TextureID }
                pcall(function()
                    inst.TextureID = ""
                end)
            end
        elseif inst:IsA("Decal") or inst:IsA("Texture") then
            FpsCapState.Visuals[inst] = { Transparency = inst.Transparency }
            pcall(function()
                inst.Transparency = 1
            end)
        elseif inst:IsA("SpecialMesh") then
            FpsCapState.Meshes[inst] = { TextureId = inst.TextureId }
            pcall(function()
                inst.TextureId = ""
            end)
        elseif inst:IsA("ParticleEmitter") or inst:IsA("Trail") or inst:IsA("Beam") or inst:IsA("Smoke") or inst:IsA("Fire") or inst:IsA("Sparkles") or inst:IsA("PointLight") or inst:IsA("SpotLight") or inst:IsA("SurfaceLight") then
            local enabledState = nil
            pcall(function()
                enabledState = inst.Enabled
                inst.Enabled = false
            end)
            FpsCapState.Effects[inst] = { Enabled = enabledState }
        end
    end

    pcall(function()
        if setfpscap then setfpscap(60) end
    end)
end

local function RefreshFpsCapMap()
    if not JHub.Flags.FpsCap then
        if FpsCapState.CurrentMap then RestoreFpsCapMap() end
        return
    end

    local targetMap = workspace:FindFirstChild("Building") and workspace.Building:FindFirstChild("WholeMap")
    if not targetMap then return end
    if FpsCapState.CurrentMap ~= targetMap then
        ApplyFpsCapMap(targetMap)
    end
end

