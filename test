-- โหลด Fluent UI Library
local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

-- สร้างหน้าต่าง UI
local Window = Fluent:CreateWindow({
    Title = "Jiramet Hub (TH)",
    SubTitle = "Webhook Manager",
    TabWidth = 160,
    Size = UDim2.fromOffset(500, 320),
    Acrylic = true, 
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

-- สร้างหมวดหมู่ (Tab)
local Tabs = {
    Webhook = Window:AddTab({ Title = "Webhook", Icon = "webhook" })
}

-- ตัวแปรเก็บสถานะ
local WebhookURL = ""
local WebhookEnabled = false

-- กล่องใส่ข้อความสำหรับ URL
local Input = Tabs.Webhook:AddInput("WebhookInput", {
    Title = "Discord Webhook URL",
    Default = "",
    Placeholder = "วางลิงก์ Webhook ของคุณที่นี่...",
    Numeric = false,
    Finished = false,
    Callback = function(Value)
        WebhookURL = Value
    end
})

-- ปุ่มเปิด/ปิดการทำงาน
local Toggle = Tabs.Webhook:AddToggle("WebhookToggle", {
    Title = "เปิดใช้งาน Auto Webhook",
    Default = false,
    Callback = function(Value)
        WebhookEnabled = Value
    end
})

------------------------------------------------------------------------
-- Logic ระบบดักจับและส่งข้อมูล (ผูกกับ UI ด้านบน)
------------------------------------------------------------------------
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local GameEndedUI_Event = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("Client"):WaitForChild("UI"):WaitForChild("GameEndedUI")

local currentRewards = {}
local currentStageInfo = {}

local function SendEndMatchLog()
    -- ตรวจสอบว่าเปิด Toggle และใส่ URL หรือยัง
    if not WebhookEnabled or WebhookURL == "" then return end

    local rewardText = ""
    if currentRewards and #currentRewards > 0 then
        for _, item in pairs(currentRewards) do
            local itemName = tostring(item.Name)
            local itemAmount = item:FindFirstChild("Amount") and tostring(item.Amount.Value) or "1"
            rewardText = rewardText .. "• " .. itemName .. " (x" .. itemAmount .. ")\n"
        end
    else
        rewardText = "ไม่มีรางวัลดรอป"
    end

    local payload = {
        embeds = {
            {
                title = "🎮 Match Ended Summary",
                color = tonumber("0x00FF00"),
                fields = {
                    { name = "🌍 ด่าน", value = currentStageInfo.World .. " - " .. currentStageInfo.Level, inline = true },
                    { name = "⚔️ โหมด", value = currentStageInfo.Gamemode .. " (" .. currentStageInfo.Difficulty .. ")", inline = true },
                    { name = "⏱️ เวลาที่ใช้", value = tostring(currentStageInfo.TotalTime) .. " วินาที", inline = true },
                    { name = "🎁 รางวัลที่ได้รับ", value = rewardText, inline = false }
                }
            }
        }
    }

    -- ฟังก์ชัน Request กลาง รองรับ Executor ส่วนใหญ่
    local req = (syn and syn.request) or http_request or request or fluxus.request
    if req then
        pcall(function()
            req({
                Url = WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
        end)
    end
end

-- ดักจับข้อมูลจากเกม
GameEndedUI_Event.OnClientEvent:Connect(function(action, data)
    -- ถ้าปิดระบบ Webhook อยู่ ให้ข้ามการทำงานไปเลย
    if not WebhookEnabled then return end

    if action == "Rewards - Items" then
        currentRewards = data
    elseif action == "Update - EndedScreen" then
        local ValuesGame = ReplicatedStorage:WaitForChild("Values"):WaitForChild("Game")
        
        currentStageInfo = {
            Gamemode = ValuesGame:WaitForChild("Gamemode").Value,
            World = ValuesGame:WaitForChild("World").Value,
            Level = ValuesGame:WaitForChild("Level").Value,
            Difficulty = ValuesGame:WaitForChild("Difficulty").Value,
            TotalTime = data.TotalTime or 0
        }
        -- ส่งข้อมูลเมื่อได้อัปเดตหน้าจอครบแล้ว
        SendEndMatchLog()
    end
end)

Fluent:Notify({
    Title = "Webhook Manager",
    Content = "โหลด UI เสร็จสิ้น กรุณาใส่ URL และกดเปิดใช้งาน",
    Duration = 5
})
