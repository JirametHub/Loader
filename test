local function SecureButton(rowObj, labelText, actionFunc)
    local isRunning = false
    local function wrappedAction()
        if isRunning then return end
        isRunning = true
        task.spawn(function()
            local success, err = pcall(actionFunc)
            if not success then ShowNotif("Action Error", "ระบบขัดข้อง: กรุณาเช็ก Console (F9)", cascade.Symbols.xmark) end
            task.wait(0.5);
            isRunning = false
        end)
    end
    local success, btnClass, btnInst = pcall(function() return rowObj:Right():Button({ Label = labelText }) end)
    local connected = false
    local function hookGui(inst)
        if typeof(inst) == "Instance" then
            local realBtn = inst:IsA("GuiButton") and inst or inst:FindFirstChildWhichIsA("GuiButton", true)
            if realBtn then realBtn.MouseButton1Click:Connect(wrappedAction);
            realBtn.TouchTap:Connect(wrappedAction); return true end
        end
        return false
    end
    if hookGui(btnInst) then connected = true end
    if not connected and type(btnClass) == "table" then
        if hookGui(btnClass.Instance) then connected = true elseif hookGui(btnClass.Frame) then connected = true elseif hookGui(btnClass.GUI) then connected = true end
        if not connected then
            for key, val in pairs(btnClass) do
                if (key:find("Click") or key:find("Activat") or key:find("Callback")) then
                    if typeof(val) == "RBXScriptSignal" or (type(val) == "table" and type(val.Connect) == "function") then
                        pcall(function() val:Connect(wrappedAction) end);
                        connected = true
                    end
                end
            end
        end
    end
    return btnClass
end

