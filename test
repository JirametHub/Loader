local function FireSafeRemote(pathTable, ...)
    local current = ReplicatedStorage
    for _, name in ipairs(pathTable) do
        if not current then return end
        current = current:FindFirstChild(name)
    end
    if current and current:IsA("RemoteEvent") then
        current:FireServer(...)
    end
end

local function FormatNumber(n)
    if not n then return "0" end
    local num = tonumber(tostring(n):gsub(",", ""))
    if not num then return tostring(n) end
    return tostring(math.floor(num)):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

